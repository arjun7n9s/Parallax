# PARALLAX production env — copy to .env.prod and fill the SECRETS.
# Used by docker-compose.prod.yml. Never commit the filled .env.prod.

# ── Public surface ────────────────────────────────────────────────────────
API_DOMAIN=api.yourdomain.me           # subdomain whose A-record points at this VM
ACME_EMAIL=you@example.com             # Let's Encrypt account email
# Your deployed frontend origin(s), JSON array. Must include the Vercel URL so
# the dashboard's browser calls aren't blocked by CORS.
ALLOWED_ORIGINS=["https://parallax-mocha-beta.vercel.app","https://api.yourdomain.me"]

# ── Auth (SECRETS — generate with: openssl rand -hex 24) ──────────────────
API_KEY=CHANGE_ME_analyst_key          # the X-API-Key analysts sign in with
ADMIN_API_KEY=CHANGE_ME_admin_key      # separate key for /admin endpoints
WEBHOOK_SECRET=CHANGE_ME_webhook_hmac  # HMAC secret for outbound webhooks

# ── LLM: cloud gateway, no GPU needed ─────────────────────────────────────
LLM_MODE=cloud
CLOUD_PROVIDER=aiml
AIML_API=CHANGE_ME_aimlapi_key
LOCAL_ONLY=false

# ── Pipeline: static + cortex only (no emulator on a normal VM) ───────────
DYNAMIC_LIVE_DEVICE=false

# ── Datastores (service names from the compose file) ──────────────────────
POSTGRES_SERVER=postgres
POSTGRES_USER=parallax
POSTGRES_PASSWORD=CHANGE_ME_db_pass
POSTGRES_DB=parallax
REDIS_HOST=redis
REDIS_PORT=6379
# Celery broker/result backend (the worker reads this directly).
REDIS_URL=redis://redis:6379/0
MINIO_SERVER=minio:9000
MINIO_ROOT_USER=parallax
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_pass
MINIO_SECURE=false

# ── Rate limiting / misc ──────────────────────────────────────────────────
RATE_LIMIT_PER_HOUR=100
LOG_LEVEL=INFO
LOG_FORMAT=json
ENVIRONMENT=production

# ── Optional threat-intel keys (leave blank to disable) ───────────────────
MALWAREBAZAAR_API_KEY=
VIRUSTOTAL_API_KEY=
