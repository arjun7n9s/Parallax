# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
node_modules/
*.tsbuildinfo
build/
site/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg

# The Python build-artifact rules above (lib/, dist/, build/) accidentally match
# the React frontend's source dir. Re-include the frontend source tree; its own
# node_modules/ and dist/ are still ignored by the patterns above.
!frontend/src/lib/
!frontend/src/lib/**
MANIFEST

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

