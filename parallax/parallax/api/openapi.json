            "type": "array"
          },
          "submitted": {
            "title": "Submitted",
            "type": "integer"
          },
          "total": {
            "title": "Total",
            "type": "integer"
          }
        },
        "required": [
          "batch_id",
          "total",
          "submitted",
          "results"
        ],
        "title": "BatchSubmissionResponse",
        "type": "object"
      },
      "BatchSubmissionResult": {
