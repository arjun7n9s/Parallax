            "type": "string"
          },
          "submission_id": {
            "title": "Submission Id",
            "type": "string"
          },
          "verdict": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Verdict"
          }
        },
        "required": [
          "submission_id",
          "file_name",
          "status"
        ],
        "title": "BatchStatusItem",
        "type": "object"
      },
      "BatchStatusResponse": {
        "description": "Per-sample status returned by GET /analyze/batch/{batch_id}.",
        "example": {
          "batch_id": "60c97ebb-a5cc-462d-84ba-ef2200f21b08",
          "by_status": {
            "complete": 1,
            "dynamic": 1
          },
          "complete": false,
          "submissions": [
            {
              "file_name": "sample-1.apk",
              "score": 78.0,
              "status": "complete",
              "submission_id": "6f1b8c6a-7c33-4b71-b1f9-1867c56f7f54",
              "verdict": "HIGH"
            },
            {
              "file_name": "sample-2.apk",
              "status": "dynamic",
              "submission_id": "2c404c37-fc5b-46ad-98f6-1f6f9a0da013"
            }
          ],
          "total": 2
        },
        "properties": {
          "batch_id": {
            "title": "Batch Id",
            "type": "string"
          },
          "by_status": {
            "additionalProperties": {
              "type": "integer"
            },
            "title": "By Status",
            "type": "object"
          },
          "complete": {
            "title": "Complete",
            "type": "boolean"
          },
          "submissions": {
            "items": {
              "$ref": "#/components/schemas/BatchStatusItem"
            },
            "title": "Submissions",
            "type": "array"
          },
          "total": {
            "title": "Total",
            "type": "integer"
          }
        },
        "required": [
          "batch_id",
          "total",
          "by_status",
          "complete",
          "submissions"
        ],
        "title": "BatchStatusResponse",
        "type": "object"
      },
      "BatchSubmissionResponse": {
        "description": "Response returned by POST /analyze/batch.",
        "example": {
          "batch_id": "60c97ebb-a5cc-462d-84ba-ef2200f21b08",
          "results": [
            {
              "file_name": "sample-1.apk",
              "status": "queued",
              "submission_id": "6f1b8c6a-7c33-4b71-b1f9-1867c56f7f54"
            },
            {
              "error": "Only .apk files are supported.",
              "file_name": "not-an-apk.txt"
            }
          ],
          "submitted": 1,
          "total": 2
        },
        "properties": {
          "batch_id": {
            "title": "Batch Id",
            "type": "string"
          },
          "results": {
            "items": {
