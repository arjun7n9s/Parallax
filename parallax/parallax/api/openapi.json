                "type": "null"
              }
            ],
            "title": "Status"
          },
          "submission_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Submission Id"
          }
        },
        "title": "BatchSubmissionResult",
        "type": "object"
      },
