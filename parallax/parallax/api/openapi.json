  "paths": {
    "/api/v1/analysis/{submission_id}": {
      "get": {
        "description": "Fetch the current status of an analysis, including triage score and active hypotheses.",
        "operationId": "get_analysis_status_api_v1_analysis__submission_id__get",
        "parameters": [
          {
            "in": "path",
            "name": "submission_id",
            "required": true,
            "schema": {
              "format": "uuid",
              "title": "Submission Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Get Analysis Status Api V1 Analysis  Submission Id  Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "security": [
          {
            "APIKeyHeader": []
          }
        ],
        "summary": "Get Analysis Status",
        "tags": [
          "Analysis"
        ]
      }
    },
