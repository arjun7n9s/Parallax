# PARALLAX Environment Variables

# API Settings
ENVIRONMENT=development
API_V1_STR=/api/v1
PROJECT_NAME=PARALLAX

# PostgreSQL (Relational metadata)
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=parallax_db_pass
POSTGRES_DB=parallax

# Redis (Task queue broker)
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO (APK storage)
MINIO_SERVER=localhost:9000
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=parallax_minio_pass
MINIO_SECURE=false

# Neo4j (TAIG Graph)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=parallax_neo4j_pass

# Qdrant (Vector DB)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Ollama (Local LLM Server)
OLLAMA_HOST=http://localhost:11434

# External APIs (Optional for synthesis agent if using cloud models)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
