# PARALLAX Environment Variables

# API Settings
ENVIRONMENT=development
API_V1_STR=/api/v1
PROJECT_NAME=PARALLAX
LOG_LEVEL=INFO

# Security
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://127.0.0.1:5173", "http://localhost:8000"]
MAX_UPLOAD_SIZE_MB=500
# API key clients must send in the X-API-Key header.
# Empty = auth DISABLED (development only — always set this in production).
API_KEY=
TENANT_ID=default
API_KEY_TENANT_MAP=
SIGNED_URL_TTL_SECONDS=300

# PostgreSQL (Relational metadata)
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=parallax_db_pass
POSTGRES_DB=parallax

# Redis (Task queue broker)
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO (APK storage)
MINIO_SERVER=localhost:9000
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=parallax_minio_pass
MINIO_SECURE=false

# Neo4j (TAIG Graph)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=parallax_neo4j_pass

# Qdrant (Vector DB)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Ollama (Local LLM Server)
OLLAMA_HOST=http://localhost:11434

# OpenTelemetry (Tracing)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# LLM provider routing: local (Ollama only) | cloud | auto (cloud if key set)
LLM_MODE=local
# Cloud backend: aiml (aimlapi.com unified gateway, recommended) | anthropic | openai
CLOUD_PROVIDER=aiml
# aimlapi.com gateway — one key for all models; per-role IDs in parallax/ai/llm.py
# AIML_API=
# AIML_BASE_URL=https://api.aimlapi.com/v1
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# External analysis tools (empty = resolve from PATH / auto-discover)
# JADX_BIN=tools/jadx/bin/jadx
# FLOWDROID_JAR=parallax/analysis/static/flowdroid_lib/soot-infoflow-cmd.jar
# ANDROID_PLATFORMS_DIR=   # e.g. $ANDROID_HOME/platforms (required by FlowDroid)
# ADB_BIN=
FLOWDROID_TIMEOUT_SECONDS=300

# Dynamic analysis on a live emulator/device (requires adb + rooted device)
DYNAMIC_LIVE_DEVICE=false
DYNAMIC_TIMEOUT_SECONDS=120
DROIDBOT_MAX_TURNS=20
# Host/port the Android device should use for mitmproxy. For Docker Desktop/WSL
# live runs, set MITM_PROXY_HOST to the host gateway reachable from the emulator.
MITM_PROXY_HOST=127.0.0.1
MITM_PROXY_PORT=8080

# Delivery webhooks: comma-separated URLs; HMAC secret signs every payload.
# If WEBHOOK_URLS is set, ALWAYS set WEBHOOK_SECRET (unsigned hooks are forgeable).
WEBHOOK_URLS=
WEBHOOK_SECRET=

# Threat intel enrichment (optional — IoC matching degrades gracefully)
VIRUSTOTAL_API_KEY=
MALWAREBAZAAR_API_KEY=
MISP_URL=
MISP_KEY=
# Only set false for a self-hosted MISP with a self-signed cert
MISP_VERIFY_TLS=true

GRAFANA_ADMIN_PASSWORD=admin
